# All variables are read via pydantic-settings with the CLAUDE_MULTI_ prefix.
# The prefix prevents the app from inheriting the user's runtime CLAUDE_CONFIG_DIR,
# which is typically set by the shell integration to an isolated account dir.

CLAUDE_MULTI_DATABASE_URL=sqlite+aiosqlite:///./claude_multi_account.db
CLAUDE_MULTI_SERVER_PORT=8765

# System-wide Claude Code config directory (where the active account lives).
CLAUDE_MULTI_ACTIVE_CLAUDE_DIR=~/.claude

# Base directory for per-account isolated config dirs.
CLAUDE_MULTI_ACCOUNTS_BASE_DIR=~/.claude-multi-accounts

# Model used for Haiku tmux monitor evaluation.
CLAUDE_MULTI_HAIKU_MODEL=claude-haiku-4-5-20251001

# Polling intervals (seconds).
CLAUDE_MULTI_POLL_INTERVAL_ACTIVE=15
CLAUDE_MULTI_POLL_INTERVAL_IDLE=300
CLAUDE_MULTI_POLL_INTERVAL_MIN=120
